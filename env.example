# ====================================
# PharmaAI - Variaveis de Ambiente
# ====================================
# Copie para um arquivo .env ou configure no terminal antes de rodar.
# NAO commite tokens reais no Git!

# OpenAI
OPENAI_API_KEY=sk-proj-SUA_CHAVE_AQUI

# WhatsApp - Token Temporario (~24h)
# Gerar em: https://developers.facebook.com > App > WhatsApp > API Setup
WHATSAPP_TOKEN=SEU_TOKEN_AQUI

# WhatsApp - Token Permanente (System User - nao expira)
# 1. Acessar https://business.facebook.com/settings/system-users
# 2. Criar System User com papel "Admin"
# 3. Gerar token com permissoes: whatsapp_business_messaging, whatsapp_business_management
# 4. Vincular WhatsApp Business Account ao System User
# WHATSAPP_TOKEN=TOKEN_PERMANENTE_AQUI

# WhatsApp - Phone Number ID (default: numero de teste)
WHATSAPP_PHONE_NUMBER_ID=979436765263547

# WhatsApp - Verify Token (para validacao do webhook)
WHATSAPP_VERIFY_TOKEN=pharmaai-verify-2024

# PostgreSQL (Docker Compose usa esses valores por padrao)
DATABASE_URL=jdbc:postgresql://localhost:5432/pharmaai
DATABASE_USER=pharmaai
DATABASE_PASSWORD=pharmaai123
